        {
            "@type": "FAQPage",
            "@id": "https://n8nera.tech/#faq",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "What is n8nera?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "n8nera is a Pakistan-based AI and automation agency serving UAE businesses remotely. They specialize in n8n workflow automation, AI voice agents, CRM automation, WhatsApp automation, and business process optimization. Founded in 2021, they've completed 200+ automation implementations with a 99.8% client satisfaction rate."
                    }
                },
                {
                    "@type": "Question",
                    "name": "What services does n8nera provide?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "n8nera provides: (1) Workflow Automation — business process, CRM, e-commerce, WhatsApp, social media automation. (2) AI & Integration — AI-based automation, data sync, monitoring, SaaS automation. (3) AI Voice Agents — call center agents, appointment booking, hotel/restaurant agents, sales AI, payment agents, logistics agents. (4) n8n Core — automation agency, workflow automation, integrations, AI automation, dedicated developer hiring."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How much does n8nera automation cost?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Starter: $500–$1,000 (1-3 workflows). Professional: $1,000–$5,000 (5-10 workflows). Enterprise: $5,000+ (unlimited). AI Voice Agents: $1,500–$3,000 setup + $300–$1,000/month."
                    }
                },
                {
                    "@type": "Question",
                    "name": "What is n8n automation?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "n8n is an open-source workflow automation platform, similar to Zapier but more powerful and customizable. It offers self-hosting capability for data privacy, 400+ built-in integrations, a visual workflow builder, AI agent support, custom code nodes, and enterprise-grade scalability — all without vendor lock-in. n8nera is a certified n8n implementation partner."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Does n8nera serve Dubai businesses?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. n8nera serves all UAE emirates including Dubai, Abu Dhabi, Sharjah, Ajman, Ras Al Khaimah, Fujairah, Umm Al Quwain, and Al Ain. All services are delivered remotely from Pakistan during UAE business hours (GST)."
                    }
                }
            ]
        },
